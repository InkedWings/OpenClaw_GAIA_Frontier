# Edit this file to change the TP2 experiment without touching the runner.

# Repository/workspace locations.
WORK="${WORK:-/lustre/orion/gen150/scratch/zye25/Agentic}"
PYTHON_BIN="${PYTHON_BIN:-/lustre/orion/gen150/scratch/zye25/conda-envs/AGAI/bin/python}"
IMG="${IMG:-${WORK}/containers/vllm-openai-rocm-nightly.sif}"
MODEL="${MODEL:-${WORK}/hf/models/Qwen3.5-27B}"
ROWS_JSONL="${ROWS_JSONL:-${GAIA_ROOT}/data/gaia_2023_all_validation/rows.jsonl}"

# vLLM backend knobs.
PORT="${PORT:-8011}"
# vLLM server context limit. This becomes vLLM's --max-model-len.
VLLM_CONTEXT_WINDOW="${VLLM_CONTEXT_WINDOW:-32768}"
GPU_MEM_UTIL="${GPU_MEM_UTIL:-0.95}"
VLLM_API_KEY="${VLLM_API_KEY:-vllm-local}"
VLLM_ENTRYPOINT="${VLLM_ENTRYPOINT:-serve}"
VLLM_GENERATION_CONFIG="${VLLM_GENERATION_CONFIG:-vllm}"
VLLM_OVERRIDE_GENERATION_CONFIG="${VLLM_OVERRIDE_GENERATION_CONFIG:-{\"temperature\":0.0,\"top_p\":1.0,\"repetition_penalty\":1.0}}"
ENABLE_PREFIX_CACHING="${ENABLE_PREFIX_CACHING:-1}"

# Qwen3.5 settings used in the working run.
# TOOL_CALL_PARSER and REASONING_PARSER are auto-selected by the Python runner.
DISABLE_VLLM_SPECULATIVE="${DISABLE_VLLM_SPECULATIVE:-1}"

# OpenClaw generation budget.
OPENCLAW_MAX_OUTPUT_TOKENS="${OPENCLAW_MAX_OUTPUT_TOKENS:-4096}"
OPENCLAW_CONTEXT_MARGIN="${OPENCLAW_CONTEXT_MARGIN:-1024}"
OPENCLAW_CONTEXT_WINDOW="${OPENCLAW_CONTEXT_WINDOW:-23552}"

# GAIA concurrency sweep.
TP_LIST="${TP_LIST:-2}"
CONCURRENCY_LIST="${CONCURRENCY_LIST:-2}"
ROUNDS="${ROUNDS:-1}"
WARMUP_COUNT="${WARMUP_COUNT:-1}"
# Select GAIA rows by original dataset idx: [IDX_START, IDX_END).
# Set IDX_END=-1 to run through the end of ROWS_JSONL.
IDX_START="${IDX_START:-0}"
IDX_END="${IDX_END:-8}"
CASE_MODE="${CASE_MODE:-all}"
TASK_TIMEOUT_S="${TASK_TIMEOUT_S:-600}"
BACKEND_READY_TIMEOUT_S="${BACKEND_READY_TIMEOUT_S:-1800}"
GPU_SAMPLE_SEC="${GPU_SAMPLE_SEC:-1.0}"

# Output/restart behavior.
RUN_NAME="${RUN_NAME:-gaia_qwen35_tp2_concurrency}"
RESUME="${RESUME:-1}"
SKIP_REPORT="${SKIP_REPORT:-0}"
